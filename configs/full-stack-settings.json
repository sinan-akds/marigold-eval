{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob",
        "hooks": [
          { "type": "command", "command": "__SCRIPTS_DIR__/block-eval-internals.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "__SCRIPTS_DIR__/block-validate-checks.sh" }
        ]
      }
    ]
  }
}
