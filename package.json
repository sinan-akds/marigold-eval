{
  "name": "bachelorarbeit-eval",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "eval": "tsx run-eval.ts",
    "eval:status": "tsx run-eval.ts --status",
    "eval:dry-run": "tsx run-eval.ts --dry-run",
    "plots:data": "tsx rebuild-benchmark.ts && tsx extract-iterations.ts",
    "plots": "pnpm plots:data && python3 make_thesis_plots.py",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6"
  }
}
