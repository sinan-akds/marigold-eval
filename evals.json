          }
        },
        {
          "id": "a-select",
          "description": "Select component for subject",
          "severity": "required",
          "check": {
            "type": "component",
            "component": "Select"
          }
        },
        {
          "id": "a-textarea",
          "description": "TextArea component for message",
          "severity": "required",
          "check": {
            "type": "component",
            "component": "TextArea"
          }
        },
        {
          "id": "a-submit-button",
          "description": "Submit button present",
          "severity": "required",
          "check": {
            "type": "component",
            "component": "Button"
          }
        },
        {
          "id": "a-form-wrapper",
          "description": "Form component wrapping fields",
          "severity": "required",
          "check": {
            "type": "component",
            "component": "Form"
          }
        },
        {
          "id": "a-no-raw-html",
          "description": "No raw HTML form elements (input, select, textarea)",
          "severity": "required",
          "check": {
            "type": "composite",
            "operator": "and",
            "checks": [
              { "type": "absence", "pattern": "input", "scope": "jsx" },
              { "type": "absence", "pattern": "select", "scope": "jsx" },
              { "type": "absence", "pattern": "textarea", "scope": "jsx" }
            ]
          }
        }
      ]
    },
